---
const { title, engine, genre, description, thumbnail, link, reverse = false } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
  <div class={`aspect-video glass rounded-3xl overflow-hidden glow-effect ${reverse ? 'md:order-2' : 'order-2 md:order-1'}`}>
    {thumbnail ? (
      <img src={thumbnail} alt={title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-brand/20 to-pink-500/10 flex items-center justify-center">
        <span class="text-gray-600 italic">No Screenshot</span>
      </div>
    )}
  </div>

  <div class={`space-y-4 ${reverse ? 'md:order-1' : 'order-1 md:order-2'}`}>
    <span class="text-sm font-bold tracking-widest uppercase text-brand">
      {genre} / {engine}
    </span>
    <h4 class="text-4xl font-extrabold tracking-tight text-white">
      {title}
    </h4>
    <p class="text-gray-400 leading-relaxed">
      {description}
    </p>
    <div class="flex gap-4 pt-6">
      <a href={link} class="px-6 py-3 glass rounded-xl text-white font-medium hover:border-brand/50 transition-colors">
        View Project
      </a>
    </div>
  </div>
</div>